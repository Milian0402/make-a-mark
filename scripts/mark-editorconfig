#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: mark-editorconfig [--repo <path>] [--force]"
  exit 1
}

repo="."
force=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo) repo="$2"; shift 2 ;;
    --force) force=true; shift ;;
    -h|--help) usage ;;
    *) echo "error: unknown arg: $1" >&2; exit 1 ;;
  esac
done

file="$repo/.editorconfig"

if [[ -f "$file" ]] && [[ "$force" != true ]]; then
  echo "error: $file already exists. Use --force to overwrite." >&2
  exit 1
fi

cat > "$file" << 'EOF'
root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
EOF

echo "Dropped $file"
