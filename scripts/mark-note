#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: mark-note -m <message> [--commit <ref>] [--force]"
  exit 1
}

message=""
commit="HEAD"
force=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    -m) message="$2"; shift 2 ;;
    --commit) commit="$2"; shift 2 ;;
    --force) force=true; shift ;;
    -h|--help) usage ;;
    *) echo "error: unknown arg: $1" >&2; exit 1 ;;
  esac
done

[[ -z "$message" ]] && { echo "error: -m <message> required" >&2; exit 1; }

if [[ "$force" == true ]]; then
  git notes add -f -m "$message" "$commit"
else
  git notes add -m "$message" "$commit"
fi

echo "Added note to $commit"
