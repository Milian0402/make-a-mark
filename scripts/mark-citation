#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: mark-citation --title <title> --author <name> [--author <name> ...] [--version <version>] [--date <YYYY-MM-DD>] [--message <text>] [--doi <doi>] [--url <url>] [--set <key=value>] [--repo <path>] [--force]"
  exit 1
}

escape_yaml() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  printf '%s' "$value"
}

require_single_line() {
  local label="$1"
  local value="$2"
  case "$value" in
    *$'\n'*|*$'\r'*)
      echo "error: $label must be a single line value" >&2
      exit 1
      ;;
  esac
}

validate_date() {
  local value="$1"
  [[ "$value" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]] || {
    echo "error: --date must be YYYY-MM-DD" >&2
    exit 1
  }
}

title=""
authors=()
version="0.1.0"
date_str=""
message="If you use this software, please cite it."
doi=""
url=""
extra_fields=()
repo="."
force=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --title) title="$2"; shift 2 ;;
    --author) authors+=("$2"); shift 2 ;;
    --version) version="$2"; shift 2 ;;
    --date) date_str="$2"; shift 2 ;;
    --message) message="$2"; shift 2 ;;
    --doi) doi="$2"; shift 2 ;;
    --url) url="$2"; shift 2 ;;
    --set) extra_fields+=("$2"); shift 2 ;;
    --repo) repo="$2"; shift 2 ;;
    --force) force=true; shift ;;
    -h|--help) usage ;;
    *) echo "error: unknown arg: $1" >&2; exit 1 ;;
  esac
done

[[ -z "$title" ]] && { echo "error: --title required" >&2; exit 1; }
[[ ${#authors[@]} -eq 0 ]] && { echo "error: at least one --author required" >&2; exit 1; }

repo="$(cd "$repo" 2>/dev/null && pwd -P)" || { echo "error: repo path not found: $repo" >&2; exit 1; }
file="$repo/CITATION.cff"

require_single_line "--title" "$title"
require_single_line "--version" "$version"
require_single_line "--message" "$message"

for author in "${authors[@]}"; do
  require_single_line "--author" "$author"
done

if [[ -n "$doi" ]]; then
  require_single_line "--doi" "$doi"
fi

if [[ -n "$url" ]]; then
  require_single_line "--url" "$url"
fi

if [[ -z "$date_str" ]]; then
  if [[ -f "$file" ]]; then
    existing_date="$(awk -F'"' '/^date-released:/ {print $2; exit}' "$file")"
    date_str="${existing_date:-$(date -u +%Y-%m-%d)}"
  else
    date_str="$(date -u +%Y-%m-%d)"
  fi
fi
validate_date "$date_str"

content="cff-version: 1.2.0
message: \"$(escape_yaml "$message")\"
title: \"$(escape_yaml "$title")\"
version: \"$(escape_yaml "$version")\"
date-released: \"$date_str\"
authors:
"

for author in "${authors[@]}"; do
  content+="  - name: \"$(escape_yaml "$author")\""$'\n'
done

if [[ -n "$url" ]]; then
  content+="repository-code: \"$(escape_yaml "$url")\""$'\n'
fi

if [[ -n "$doi" ]]; then
  content+="doi: \"$(escape_yaml "$doi")\""$'\n'
fi

for kv in "${extra_fields[@]}"; do
  eq="${kv%%=*}"
  val="${kv#*=}"
  if [[ "$eq" == "$kv" ]]; then
    echo "error: --set expects key=value, got: $kv" >&2
    exit 1
  fi
  [[ "$eq" =~ ^[a-z][a-z0-9-]*$ ]] || {
    echo "error: invalid --set key: $eq (expected lowercase letters, numbers, hyphen)" >&2
    exit 1
  }
  require_single_line "--set" "$val"
  content+="$eq: \"$(escape_yaml "$val")\""$'\n'
done

if [[ -f "$file" ]]; then
  [[ ! -L "$file" ]] || { echo "error: refusing to overwrite symlink: $file" >&2; exit 1; }
  existing="$(cat "$file")"
  if [[ "$existing" == "${content%$'\n'}" ]]; then
    echo "CITATION.cff already up to date"
    exit 0
  fi
  if [[ "$force" != true ]]; then
    echo "error: $file already exists with different content. Use --force to overwrite." >&2
    exit 1
  fi
fi

printf "%s" "$content" > "$file"

echo "Dropped $file"
