#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: mark-pr --title <title> [--body <text>] [--base <branch>] [--draft]"
  exit 1
}

title=""
body=""
base="main"
draft=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --title) title="$2"; shift 2 ;;
    --body) body="$2"; shift 2 ;;
    --base) base="$2"; shift 2 ;;
    --draft) draft=true; shift ;;
    -h|--help) usage ;;
    *) echo "error: unknown arg: $1" >&2; exit 1 ;;
  esac
done

[[ -z "$title" ]] && { echo "error: --title required" >&2; exit 1; }

args=(--title "$title" --base "$base")
[[ -n "$body" ]] && args+=(--body "$body")
[[ "$draft" == true ]] && args+=(--draft)

gh pr create "${args[@]}"
