#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: mark-gitignore [--preset <general|node|python>] [--pattern <entry>]... [--block <name>] [--repo <path>] [--allow-symlink]"
  exit 1
}

preset="general"
repo="."
custom_patterns=()
block_name=""
allow_symlink=false

require_single_line() {
  local label="$1"
  local value="$2"
  case "$value" in
    *$'\n'*|*$'\r'*)
      echo "error: $label must be single-line text" >&2
      exit 1
      ;;
  esac
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --preset) preset="$2"; shift 2 ;;
    --pattern) custom_patterns+=("$2"); shift 2 ;;
    --block) block_name="$2"; shift 2 ;;
    --repo) repo="$2"; shift 2 ;;
    --allow-symlink) allow_symlink=true; shift ;;
    -h|--help) usage ;;
    *) echo "error: unknown arg: $1" >&2; exit 1 ;;
  esac
done

case "$preset" in
  general)
    patterns=(
      ".DS_Store"
      "*.log"
      ".env"
      ".env.*"
      "coverage/"
      "dist/"
      "tmp/"
    )
    ;;
  node)
    patterns=(
      "node_modules/"
      "npm-debug.log*"
      "yarn-debug.log*"
      "yarn-error.log*"
      ".pnpm-debug.log*"
      ".turbo/"
    )
    ;;
  python)
    patterns=(
      "__pycache__/"
      "*.py[cod]"
      ".venv/"
      "venv/"
      ".pytest_cache/"
      ".mypy_cache/"
    )
    ;;
  *)
    echo "error: unknown preset: $preset. Use general, node, or python." >&2
    exit 1
    ;;
esac

for pattern in "${custom_patterns[@]}"; do
  require_single_line "--pattern" "$pattern"
  patterns+=("$pattern")
done

[[ ${#patterns[@]} -gt 0 ]] || { echo "error: no gitignore patterns provided" >&2; exit 1; }

if [[ -n "$block_name" ]]; then
  [[ "$block_name" =~ ^[a-z0-9-]+$ ]] || {
    echo "error: --block must match [a-z0-9-]+" >&2
    exit 1
  }
else
  block_name="$preset"
fi

repo="$(cd "$repo" 2>/dev/null && pwd -P)" || { echo "error: repo path not found: $repo" >&2; exit 1; }
file="$repo/.gitignore"
start="# >>> make-a-mark:gitignore:$block_name >>>"
end="# <<< make-a-mark:gitignore:$block_name <<<"

tmp="$(mktemp)"
trap 'rm -f "$tmp"' EXIT

if [[ -L "$file" ]] && [[ "$allow_symlink" != true ]]; then
  echo "error: refusing to write symlinked .gitignore without --allow-symlink" >&2
  exit 1
fi

if [[ -f "$file" ]]; then
  awk -v start="$start" -v end="$end" '
    $0 == start { skip = 1; next }
    $0 == end { skip = 0; next }
    skip == 0 { print }
  ' "$file" > "$tmp"
else
  : > "$tmp"
fi

if [[ -s "$tmp" ]]; then
  printf "\n" >> "$tmp"
fi

{
  echo "$start"
  for pattern in "${patterns[@]}"; do
    echo "$pattern"
  done
  echo "$end"
} >> "$tmp"

mv "$tmp" "$file"

echo "Updated $file with $preset preset"
