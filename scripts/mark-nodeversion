#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: mark-nodeversion --version <version> [--format nvmrc|node-version] [--repo <path>] [--force]"
  exit 1
}

version=""
format="nvmrc"
repo="."
force=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --version) version="$2"; shift 2 ;;
    --format) format="$2"; shift 2 ;;
    --repo) repo="$2"; shift 2 ;;
    --force) force=true; shift ;;
    -h|--help) usage ;;
    *) echo "error: unknown arg: $1" >&2; exit 1 ;;
  esac
done

[[ -z "$version" ]] && { echo "error: --version required" >&2; exit 1; }

case "$format" in
  nvmrc)        file="$repo/.nvmrc" ;;
  node-version) file="$repo/.node-version" ;;
  *) echo "error: unknown format: $format. Use nvmrc or node-version." >&2; exit 1 ;;
esac

if [[ -f "$file" ]] && [[ "$force" != true ]]; then
  echo "error: $file already exists. Use --force to overwrite." >&2
  exit 1
fi

echo "$version" > "$file"
echo "Dropped $file ($version)"
