#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: mark-lint-staged [--repo <path>] [--force]"
  exit 1
}

repo="."
force=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo) repo="$2"; shift 2 ;;
    --force) force=true; shift ;;
    -h|--help) usage ;;
    *) echo "error: unknown arg: $1" >&2; exit 1 ;;
  esac
done

config="$repo/.lintstagedrc.json"
hook_dir="$repo/.husky"
hook_file="$hook_dir/pre-commit"

if [[ -f "$config" ]] && [[ "$force" != true ]]; then
  echo "error: $config already exists. Use --force to overwrite." >&2
  exit 1
fi

cat > "$config" << 'JSON'
{
  "*.{ts,tsx,js,jsx}": ["eslint --fix", "prettier --write"],
  "*.{json,md,yml,yaml}": ["prettier --write"],
  "*.css": ["prettier --write"]
}
JSON

echo "Dropped $config"

mkdir -p "$hook_dir"

if [[ -f "$hook_file" ]] && [[ "$force" != true ]]; then
  if grep -qF "lint-staged" "$hook_file"; then
    echo "lint-staged hook already in $hook_file"
    exit 0
  fi
fi

cat > "$hook_file" << 'HOOK'
#!/usr/bin/env sh
npx --no -- lint-staged
HOOK

chmod +x "$hook_file"
echo "Dropped $hook_file"
