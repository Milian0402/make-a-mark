#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: mark-robots [--sitemap <url>] [--disallow <path>] [--repo <path>] [--force]"
  exit 1
}

sitemap=""
disallow=""
repo="."
force=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --sitemap) sitemap="$2"; shift 2 ;;
    --disallow) disallow="$2"; shift 2 ;;
    --repo) repo="$2"; shift 2 ;;
    --force) force=true; shift ;;
    -h|--help) usage ;;
    *) echo "error: unknown arg: $1" >&2; exit 1 ;;
  esac
done

robots="$repo/robots.txt"

if [[ -f "$robots" ]] && [[ "$force" != true ]]; then
  echo "error: $robots already exists. Use --force to overwrite." >&2
  exit 1
fi

{
  echo "# robots.txt — dropped by make-a-mark"
  echo ""
  echo "User-agent: *"
  if [[ -n "$disallow" ]]; then
    echo "Disallow: $disallow"
  else
    echo "Allow: /"
  fi
  if [[ -n "$sitemap" ]]; then
    echo ""
    echo "Sitemap: $sitemap"
  fi
} > "$robots"

echo "Dropped $robots"
