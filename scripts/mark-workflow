#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: mark-workflow --name <name> [--trigger <push|pr|schedule>] [--repo <path>] [--force]"
  exit 1
}

name=""
trigger="push"
repo="."
force=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --name) name="$2"; shift 2 ;;
    --trigger) trigger="$2"; shift 2 ;;
    --repo) repo="$2"; shift 2 ;;
    --force) force=true; shift ;;
    -h|--help) usage ;;
    *) echo "error: unknown arg: $1" >&2; exit 1 ;;
  esac
done

[[ -z "$name" ]] && { echo "error: --name required" >&2; exit 1; }

slug=$(echo "$name" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr -cd 'a-z0-9-')
file="$repo/.github/workflows/${slug}.yml"

if [[ -f "$file" ]] && [[ "$force" != true ]]; then
  echo "error: $file already exists. Use --force to overwrite." >&2
  exit 1
fi

mkdir -p "$repo/.github/workflows"

case "$trigger" in
  push)
    on_block="on:
  push:
    branches: [main]"
    ;;
  pr)
    on_block="on:
  pull_request:
    branches: [main]"
    ;;
  schedule)
    on_block="on:
  schedule:
    - cron: '0 9 * * 1'"
    ;;
  *) echo "error: unknown trigger: $trigger. Use push, pr, or schedule." >&2; exit 1 ;;
esac

cat > "$file" << EOF
name: $name

$on_block

jobs:
  run:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
EOF

echo "Dropped $file"
