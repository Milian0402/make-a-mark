#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: mark-config --tool <name> [--repo <path>] [--force]"
  exit 1
}

tool=""
repo="."
force=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --tool) tool="$2"; shift 2 ;;
    --repo) repo="$2"; shift 2 ;;
    --force) force=true; shift ;;
    -h|--help) usage ;;
    *) echo "error: unknown arg: $1" >&2; exit 1 ;;
  esac
done

[[ -z "$tool" ]] && { echo "error: --tool required" >&2; exit 1; }

config_file="$repo/.$tool.yml"

if [[ -f "$config_file" ]] && [[ "$force" != true ]]; then
  echo "error: $config_file already exists. Use --force to overwrite." >&2
  exit 1
fi

date_str="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

cat > "$config_file" << YAML
# $tool configuration
# Dropped by make-a-mark on $date_str

tool: $tool
version: "1.0"
enabled: true
YAML

echo "Dropped $config_file"
